# === OBRIGATÓRIO ===
ANTHROPIC_API_KEY=sk-ant-...

# === GERAÇÃO DE IMAGENS (fal.ai) ===
FAL_KEY=...

# === LINKEDIN ===
# Crie um app em: https://developer.linkedin.com/
# Permissões: w_member_social, r_liteprofile
LINKEDIN_ACCESS_TOKEN=...
LINKEDIN_PERSON_URN=urn:li:person:...

# === INSTAGRAM (via Facebook Graph API) ===
# Requer conta Business conectada a uma Page do Facebook
# https://developers.facebook.com/docs/instagram-api
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_ACCOUNT_ID=...

# === TIKTOK ===
# https://developers.tiktok.com/doc/content-posting-api-get-started
TIKTOK_ACCESS_TOKEN=...
TIKTOK_OPEN_ID=...

# === YOUTUBE (Google OAuth2) ===
# Baixe o arquivo credentials.json em: https://console.cloud.google.com/
YOUTUBE_CREDENTIALS_FILE=credentials.json

# === MEDIUM ===
# Gere em: https://medium.com/me/settings → Integration tokens
MEDIUM_INTEGRATION_TOKEN=...

# === VÍDEO (D-ID Talking Head) ===
# https://www.d-id.com/api/
DID_API_KEY=...
DID_PRESENTER_IMAGE_URL=...
