# === OBRIGATÓRIO ===
ANTHROPIC_API_KEY=sk-ant-...

# === GERAÇÃO DE IMAGENS (fal.ai) ===
# Cadastre em: https://fal.ai — Free tier disponível
FAL_KEY=...

# === LINKEDIN ===
# Crie um app em: https://developer.linkedin.com/
# Products necessários: "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect"
# Redirect URI: http://localhost:8080/callback
# Execute: python3 linkedin_auth.py  (gera token automaticamente)
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...
LINKEDIN_ACCESS_TOKEN=...
LINKEDIN_PERSON_URN=urn:li:person:...

# === INSTAGRAM (via Facebook Graph API) ===
# Requer conta Business conectada a uma Page do Facebook
# https://developers.facebook.com/docs/instagram-api
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_ACCOUNT_ID=...

# === CLOUDINARY (hosting de imagens para Instagram) ===
# Cadastre em: https://cloudinary.com — Free tier: 25GB storage/mês
# Formato: cloudinary://api_key:api_secret@cloud_name
# Exemplo:  cloudinary://123456789012345:abcDEFghiJKL@meu-cloud
CLOUDINARY_URL=cloudinary://...

# === TIKTOK ===
# https://developers.tiktok.com/doc/content-posting-api-get-started
TIKTOK_ACCESS_TOKEN=...
TIKTOK_OPEN_ID=...

# === YOUTUBE (Google OAuth2) ===
# Baixe o arquivo credentials.json em: https://console.cloud.google.com/
# APIs & Services > Credenciais > Criar > ID de cliente OAuth 2.0 > Desktop app
YOUTUBE_CREDENTIALS_FILE=credentials.json

# === MEDIUM ===
# Gere em: https://medium.com/me/settings → Integration tokens
MEDIUM_INTEGRATION_TOKEN=...

# === VÍDEO (D-ID Talking Head) ===
# https://www.d-id.com/api/ — Free tier: 5 créditos/mês
DID_API_KEY=...
DID_PRESENTER_IMAGE_URL=https://...

# === NEWSAPI (opcional — melhora busca de notícias) ===
# Cadastre em: https://newsapi.org — Free tier: 100 req/dia
# Se configurado, será usado como fonte primária de notícias
NEWSAPI_KEY=...
